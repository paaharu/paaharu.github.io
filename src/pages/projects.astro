---
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';
---

<Layout title="Works | paaharu">
  <div class="max-w-5xl mx-auto px-6 py-16 grid gap-12">

    <div class="grid gap-2">
      <p class="text-xs text-zinc-400 tracking-widest uppercase">Works</p>
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900">Projects</h1>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((project) => (
        <article class="group bg-white border border-zinc-200 rounded-xl p-6 hover:border-zinc-400 hover:shadow-sm transition-all grid gap-4">
          <div class="grid gap-2">
            <h2 class="font-semibold text-zinc-900">{project.title}</h2>
            <p class="text-sm text-zinc-500 leading-relaxed">{project.description}</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {project.tech.map((t) => (
              <span class="text-xs bg-zinc-100 text-zinc-600 px-2 py-1 rounded-md">{t}</span>
            ))}
          </div>
          <a
            href={project.link}
            class="text-sm text-zinc-400 group-hover:text-zinc-700 transition-colors"
          >
            詳細を見る →
          </a>
        </article>
      ))}
    </div>

  </div>
</Layout>
