---
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';
---

<Layout>
  <main style="padding: var(--space-32);">
    <h1>プロジェクト一覧</h1>
    <div style="display: grid; gap: var(--space-16);">
      {projects.map((project) => (
        <article style="border: 1px solid var(--border-color); padding: var(--space-16); border-radius: 8px;">
          <h2>{project.title}</h2>
          <p>{project.description}</p>
          <div style="display: flex; gap: var(--space-8);">
            {project.tech.map((t) => (
              <span style="background: #eee; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem;">{t}</span>
            ))}
          </div>
          <a href={project.link} style="display: block; margin-top: var(--space-8);">詳細を見る</a>
        </article>
      ))}
    </div>
    <div style="margin-top: var(--space-32);">
      <a href="/">← ホームに戻る</a>
    </div>
  </main>
</Layout>
