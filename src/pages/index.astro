---
import Layout from '../layouts/Layout.astro';

const siteStart = new Date('2026-04-15');
const today = new Date();
const daysSince = Math.floor((today.getTime() - siteStart.getTime()) / (1000 * 60 * 60 * 24));
---

<Layout title="paaru">
  <div class="max-w-5xl mx-auto px-6 py-12 grid gap-16">

    <!-- Hero -->
    <section class="flex items-center justify-between gap-8 pb-32">
      <div class="grid gap-8">
        <div class="grid gap-32">
          <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-zinc-900 leading-tight">
            Paaru's<br class="md:hidden" /><span class="whitespace-nowrap"> Home Page</span>
          </h1>
          <p class="text-lg text-zinc-500 max-w-md leading-relaxed">
            UEC25 I類<br />情報系の勉強を頑張っています。
          </p>
        </div>
        <a
          href="/projects"
          class="inline-flex items-center gap-2 bg-zinc-900 text-white text-sm font-medium px-5 py-3 rounded-lg hover:bg-zinc-700 transition-colors w-fit"
        >
          Works を見る <span aria-hidden="true">→</span>
        </a>
      </div>
      <img
        src="/mitokon.png"
        alt="アイコン"
        class="w-56 h-56 rounded-full object-cover shrink-0 border border-zinc-200"
      />
    </section>

    <hr class="border-zinc-200" />

    <!-- About -->
    <section class="grid gap-4">
      <h2 class="text-xs font-semibold text-zinc-400 tracking-widest uppercase">About</h2>
      <p class="text-zinc-600 max-w-2xl leading-relaxed">
        理系大学で情報系を専攻しています。プログラミングや新しい技術を探ることが好きで、
        学んだことや作ったものをこのサイトで公開しています。
      </p>
      <a
        href="/about"
        class="inline-flex items-center gap-2 bg-zinc-200 text-zinc-900 text-sm font-medium px-4 py-2 rounded-lg hover:bg-zinc-300 transition-colors w-fit"
      >
        More About <span aria-hidden="true">→</span>
      </a>
    </section>

    <hr class="border-zinc-200" />

    <!-- Social -->
    <section class="grid gap-4">
      <h2 class="text-xs font-semibold text-zinc-400 tracking-widest uppercase">Social</h2>
      <div class="flex gap-6 justify-center">
        <a href="https://github.com/paaharu" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-4 border border-zinc-200 rounded-xl px-8 py-6 text-zinc-700 hover:text-zinc-900 hover:border-zinc-400 transition-colors" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 shrink-0">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="text-lg font-medium">GitHub</span>
        </a>
        <a href="https://twitter.com/" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-4 border border-zinc-200 rounded-xl px-8 py-6 text-zinc-700 hover:text-zinc-900 hover:border-zinc-400 transition-colors" aria-label="Twitter / X">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 shrink-0">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span class="text-lg font-medium">Twitter</span>
        </a>
      </div>
    </section>

    <hr class="border-zinc-200" />

    <!-- Interests -->
    <section class="grid gap-4">
      <h2 class="text-xs font-semibold text-zinc-400 tracking-widest uppercase">Interests</h2>
      <ul class="grid gap-2 text-sm text-zinc-600 list-disc list-inside">
        <li>趣味 1（後で更新）</li>
        <li>趣味 2（後で更新）</li>
        <li>趣味 3（後で更新）</li>
      </ul>
    </section>

    <hr class="border-zinc-200" />

    <!-- Site age -->
    <section>
      <p class="text-sm text-zinc-400">
        このサイトができてから <span class="font-semibold text-zinc-700">{daysSince}</span> 日
      </p>
    </section>

  </div>
</Layout>
